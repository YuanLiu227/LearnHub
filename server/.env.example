# ============================================
# Hot Monitor - 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# 注意: .env 文件已被 .gitignore 排除，不会提交到 Git

# ===== DeepSeek API（AI 服务）=====
# 用于：内容摘要、AI 质量评估
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ===== YouTube Data API v3 =====
# 用于：YouTube 视频搜索 + 博主视频收集
# 获取地址：https://console.cloud.google.com/ → API 和服务 → 库 → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# YouTube API 代理地址（国内访问需要，如 http://127.0.0.1:7890）
YOUTUBE_PROXY_URL=http://127.0.0.1:7890

# ===== Bilibili（免费，无需 Key）=====
# Bilibili 关键词搜索的视频质量阈值（博主收集不使用阈值）
BILIBILI_MIN_VIEWS=5000
BILIBILI_MIN_LIKES=200
BILIBILI_MIN_FAVORITES=100

# ===== YouTube 关键词搜索阈值（博主收集不使用阈值）=====
YOUTUBE_MIN_VIEWS=10000
YOUTUBE_MIN_LIKES=500

# ===== 邮件通知（SMTP，可选）=====
# 用于：搜索结果邮件通知
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=YourName <your-email@gmail.com>
NOTIFICATION_EMAIL=recipient@example.com

# ===== JWT 密钥（用户认证）=====
# 用于签发用户登录令牌，请务必修改为随机字符串
JWT_SECRET=your-jwt-secret-key

# ===== 服务器配置 =====
PORT=3001

# ===== 数据库配置（可选）=====
# DB_PATH=./data/hot-monitor.db

# ===== 数据源开关 =====
ENABLE_CODENAV=true             # 编程导航（免费）
ENABLE_AI_CODEFATHER=true       # 鱼皮AI导航（免费）
